# Copy to `.env` in this directory. Do not commit `.env`.
# Keys are loaded automatically when you start the backend (no need to export in the shell).

# --- LLM providers (set at least one that matches the models you use) ---
# Google Gemini (either name works)
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=
# Optional override (default https://api.deepseek.com)
# DEEPSEEK_BASE_URL=

# Kimi / Moonshot (OpenAI-compatible: https://api.moonshot.ai/v1 — use https://api.moonshot.cn/v1 if your account is China)
MOONSHOT_API_KEY=
# KIMI_API_KEY=   # alias for MOONSHOT_API_KEY
# MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
# Default model when remapping from Gemini without a key (see llm_client.py)
# MOONSHOT_DEFAULT_MODEL=kimi-k2.5

# --- Optional: defaults / tuning ---
# When multiple provider API keys are set, bias auto-picked defaults / Gemini→fallback remapping:
# PRIMARY_LLM=gemini | deepseek | kimi
# BASE_MODEL=gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_VISION_MODEL=gemini-2.5-flash

# LLM_MAX_TOKENS=1400
# CLAUDE_MAX_TOKENS=1400
# LLM_MAX_TOKENS_CHAT=4096
# LLM_MAX_TOKENS_APPLY=8192

# --- Web search (assistant) ---
TAVILY_API_KEY=

# Copy to `.env` in this directory (or export in your shell). Do not commit `.env`.

# --- LLM providers (set at least one that matches the models you use) ---
# Google Gemini (either name works)
GEMINI_API_KEY=
# GOOGLE_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=
# Optional override (default https://api.deepseek.com)
# DEEPSEEK_BASE_URL=

# --- Optional: defaults / tuning ---
# BASE_MODEL=gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-flash
# GEMINI_VISION_MODEL=gemini-2.5-flash

# LLM_MAX_TOKENS=1400
# CLAUDE_MAX_TOKENS=1400
# LLM_MAX_TOKENS_CHAT=4096
# LLM_MAX_TOKENS_APPLY=8192

# --- Web search (assistant) ---
TAVILY_API_KEY=
